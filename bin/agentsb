#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "rich>=13.7",
#     "pyyaml>=6.0",
# ]
# ///
"""agentsb entry point.

This file is a thin shim: it adds the project's `src/` directory to
`sys.path` and delegates to `agentsb.cli.main`. All business logic lives
in `src/agentsb/*.py` — see that package for the real code.
"""
from __future__ import annotations

import sys
from pathlib import Path


def _add_src_to_path() -> None:
    """Find the src/ directory and make `agentsb` importable.

    Supports two layouts:
      - dev checkout:       <repo>/bin/agentsb and <repo>/src/agentsb/
      - Homebrew install:   libexec/agentsb and libexec/src/agentsb/

    In both cases the parent of this script has a sibling or nested
    `src/agentsb` directory.
    """
    here = Path(__file__).resolve().parent
    candidates = (
        here / "src",            # installed: libexec/agentsb + libexec/src/agentsb
        here.parent / "src",     # dev:       repo/bin/agentsb + repo/src/agentsb
    )
    for src in candidates:
        if (src / "agentsb" / "__init__.py").is_file():
            sys.path.insert(0, str(src))
            return
    raise SystemExit(f"agentsb: could not locate src/agentsb next to {here}")


_add_src_to_path()

from agentsb.cli import main  # noqa: E402  (must come after sys.path edit)


if __name__ == "__main__":
    sys.exit(main())
